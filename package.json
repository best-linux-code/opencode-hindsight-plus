{
  "name": "opencode-hindsight-plus",
  "version": "0.3.8",
  "description": "Hindsight memory plugin for OpenCode with Claude-aligned Hindsight for OpenCode: per-project banks, transform-local recall, synthetic-user inject, knowledge pages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "opencode",
    "ai",
    "memory",
    "hindsight",
    "agents",
    "llm",
    "long-term-memory",
    "coding-agent"
  ],
  "author": "best-linux-code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/best-linux-code/opencode-hindsight-plus.git"
  },
  "bugs": {
    "url": "https://github.com/best-linux-code/opencode-hindsight-plus/issues"
  },
  "homepage": "https://github.com/best-linux-code/opencode-hindsight-plus#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "HINDSIGHT_LIVE_E2E=1 vitest run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.13",
    "@vectorize-io/hindsight-client": "^0.4.19"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "picomatch": ">=2.3.2 <3.0.0 || >=4.0.4",
    "vite": ">=8.0.5",
    "esbuild": "^0.28.1"
  }
}
